{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "lockedBalance": { "type": "number" },
        "withdrawalAccounts": { "type": "array" },
        "pin": { "type": "string" },
        "freeSpins": { "type": "number" },
        "joiningDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "referredBy": { "type": "string" },
        "referralCode": { "type": "string" },
        "appBonusClaimed": { "type": "boolean" },
        "lastDailyCheckin": { "type": "string", "format": "date-time" },
        "referralStats": {
          "type": "object",
          "properties": {
            "totalInvited": { "type": "number" },
            "activeMembers": { "type": "number" },
            "totalCommission": { "type": "number" }
          }
        }
      },
      "required": ["uid", "name", "email", "balance", "status"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Record of a user's deposit for activation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["activation", "regular"] },
        "transactionId": { "type": "string" }
      },
      "required": ["userId", "amount", "method", "status", "date"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Record of a user's withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "method", "status", "date"]
    },
    "PartnerRequest": {
      "title": "Partner Request",
      "description": "Request to upgrade to partner status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "timestamp"]
    },
    "Lottery": {
      "title": "Lottery",
      "description": "Active and completed lottery draws",
      "type": "object",
      "properties": {
        "fee": { "type": "number" },
        "maxMembers": { "type": "number" },
        "currentMembers": { "type": "number" },
        "prizePool": { "type": "number" },
        "drawDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "color": { "type": "string" }
      },
      "required": ["fee", "maxMembers", "currentMembers", "status"]
    },
    "LotteryEntry": {
      "title": "Lottery Entry",
      "description": "Record of a user joining a lottery",
      "type": "object",
      "properties": {
        "lotteryId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["lotteryId", "userId", "timestamp"]
    },
    "LotteryWinner": {
      "title": "Lottery Winner",
      "description": "Record of a lottery winner",
      "type": "object",
      "properties": {
        "lotteryId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "prize": { "type": "number" },
        "lotteryName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["lotteryId", "userId", "userName", "prize", "timestamp"]
    },
    "SpinWinner": {
      "title": "Spin Winner",
      "description": "Record of a recent spin wheel winner",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "prize": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "prize", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification or message for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["welcome", "activation", "deposit", "withdrawal", "verification", "system"] },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "status", "timestamp"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "activationFee": { "type": "number" },
        "partnerFee": { "type": "number" },
        "paymentNumber": { "type": "string" },
        "paymentName": { "type": "string" },
        "referralBonusBasic": { "type": "number" },
        "referralBonusPartner": { "type": "number" },
        "indirectReferralBonus": { "type": "number" }
      },
      "required": ["activationFee", "partnerFee", "paymentNumber", "paymentName"]
    },
    "promotion_orders": {
      "title": "Promotion Order",
      "description": "Social media growth orders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "platform": { "type": "string" },
        "service": { "type": "string" },
        "link": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "service", "link", "quantity", "price", "status"]
    },
    "Ad": {
      "title": "Video Ad",
      "description": "Available video ads for watching",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "reward": { "type": "number" },
        "duration": { "type": "number" },
        "videoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["title", "reward", "duration", "videoUrl", "status"]
    },
    "UserAdStats": {
      "title": "User Ad Stats",
      "description": "Daily tracking of ad watches per user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "counts": { "type": "object" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "counts"]
    },
    "UserAdLocks": {
      "title": "User Ad Locks",
      "description": "Tracking of 24h locks for video ads",
      "type": "object",
      "properties": {
        "userId": { "type": "string" }
      }
    },
    "EarningTransaction": {
      "title": "Earning Transaction",
      "description": "Record of a user's earning activity",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "source": { "type": "string", "enum": ["ad_watch", "task", "spin", "lottery", "referral", "app_bonus", "daily_reward", "commission", "social_task"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "source", "timestamp"]
    },
    "SocialTask": {
      "title": "Social Task",
      "description": "Social media task for users to complete",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "platform": { "type": "string", "enum": ["YouTube", "Facebook", "Instagram", "TikTok", "Telegram", "Twitter"] },
        "reward": { "type": "number" },
        "link": { "type": "string" },
        "instructions": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "platform", "reward", "link", "status"]
    },
    "SocialTaskSubmission": {
      "title": "Social Task Submission",
      "description": "User submission for a social task",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "proof": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "reward": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "userId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/social_tasks/{taskId}": {
      "schema": "SocialTask",
      "description": "Available social media tasks"
    },
    "/social_task_submissions/{submissionId}": {
      "schema": "SocialTaskSubmission",
      "description": "User submissions for social tasks"
    },
    "/earning_history/{transactionId}": {
      "schema": "EarningTransaction",
      "description": "History of all user earning activities"
    },
    "/user_ad_locks/{userId}": {
      "schema": "UserAdLocks",
      "description": "24h locks for video ads per user"
    },
    "/user_ad_stats/{statId}": {
      "schema": "UserAdStats",
      "description": "Daily ad watch statistics for users"
    },
    "/promotion_orders/{orderId}": {
      "schema": "promotion_orders",
      "description": "Collection for social media promotion orders"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Collection for available video ads"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific system notifications"
    },
    "/lotteries/{lotteryId}": {
      "schema": "Lottery",
      "description": "Lottery draw data"
    },
    "/lottery_entries/{entryId}": {
      "schema": "LotteryEntry",
      "description": "User entries into lotteries"
    },
    "/lottery_winners/{winnerId}": {
      "schema": "LotteryWinner",
      "description": "Historical lottery winners"
    },
    "/spin_winners/{winnerId}": {
      "schema": "SpinWinner",
      "description": "Recent spin wheel winners for live feed"
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "User deposit requests"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "User withdrawal requests"
    },
    "/partnerRequests/{requestId}": {
      "schema": "PartnerRequest",
      "description": "User partner upgrade requests"
    },
    "/app_settings/{settingsId}": {
      "schema": "AppSettings",
      "description": "Global application settings"
    }
  }
}
