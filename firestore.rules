rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'balance']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.balance is number;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Lotteries
    match /lotteries/{lotteryId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin via console/backend
    }

    // Lottery entries
    match /lottery_entries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['lotteryId', 'userId', 'timestamp']);
    }

    // Lottery winners
    match /lottery_winners/{winnerId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin
    }

    // Spin winners
    match /spin_winners/{winnerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['userId', 'userName', 'prize', 'timestamp']);
    }
  }
}
